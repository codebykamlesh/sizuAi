# ── Telegram API Credentials ────────────────────────────────────────────
API_ID=your_api_id_here
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# ── Owner ────────────────────────────────────────────────────────────────
OWNER_ID=your_telegram_user_id
# Optional: comma-separated sudo user IDs
SUDO_USERS=

# ── MongoDB (leave empty to use in-memory fallback) ─────────────────────
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=SizuAI

# ── Gemini & OpenRouter AI ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=your_openrouter_api_key_here
FALLBACK_MODEL_1=openai/gpt-oss-20b:free
FALLBACK_MODEL_2=z-ai/glm-4.5-air:free
FALLBACK_MODEL_3=moonshotai/kimi-k2.6:free

MAX_MEMORY=20
MAX_TOKENS=512
AI_TEMPERATURE=0.9


# ── Group Behavior ───────────────────────────────────────────────────────
# Words that trigger Sizu to reply in groups (comma-separated)
TRIGGER_WORDS=sizu,hey sizu,yo sizu

# ── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_MESSAGES=5
RATE_LIMIT_WINDOW=10

# ── Hosting (Render) ─────────────────────────────────────────────────────
PORT=8080
KEEPALIVE=true
